{
  "name": "hospitality-ops-backend",
  "version": "1.0.0",
  "description": "Hospitality Operations Management System - Backend API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
    "seed": "knex seed:run --knexfile src/db/knexfile.js",
    "migrate:make": "knex migrate:make --knexfile src/db/knexfile.js"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "jsonwebtoken": "^9.0.2",
    "argon2": "^0.41.1",
    "zod": "^3.24.2",
    "sharp": "^0.33.5",
    "opossum": "^8.4.2",
    "node-cron": "^3.0.3",
    "ioredis": "^5.4.2",
    "uuid": "^11.1.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "pino": "^9.6.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "vitest": "^3.0.4",
    "supertest": "^7.0.0",
    "@vitest/coverage-v8": "^3.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
